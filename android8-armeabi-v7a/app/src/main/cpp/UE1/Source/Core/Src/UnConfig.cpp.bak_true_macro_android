static int UE1AndroidConfigLowerAsciiRev38( int C )
{
    return ( C >= 'A' && C <= 'Z' ) ? ( C + ( 'a' - 'A' ) ) : C;
}

static int UE1AndroidConfigStrEqNoCaseRev38( const char* A, const char* B )
{
    if( !A || !B )
        return 0;

    while( *A && *B )
    {
        if( UE1AndroidConfigLowerAsciiRev38( (unsigned char)*A ) != UE1AndroidConfigLowerAsciiRev38( (unsigned char)*B ) )
            return 0;

        ++A;
        ++B;
    }

    return *A == 0 && *B == 0;
}

static const char* UE1AndroidConfigBaseNameRev38( const char* Filename )
{
    const char* Base = Filename;

    for( const char* P = Filename; P && *P; ++P )
    {
        if( *P == '/' || *P == '\\' || *P == ':' )
            Base = P + 1;
    }

    return Base;
}

static int UE1AndroidConfigHasIniExtensionRev38( const char* Filename )
{
    if( !Filename || !Filename[0] )
        return 0;

    const char* Base = UE1AndroidConfigBaseNameRev38( Filename );
    const char* Dot = strrchr( Base, '.' );

    return Dot && UE1AndroidConfigStrEqNoCaseRev38( Dot, ".ini" );
}

static int UE1AndroidConfigIsAbsolutePathRev38( const char* Filename )
{
    if( !Filename || !Filename[0] )
        return 0;

    if( Filename[0] == '/' )
        return 1;

    if( Filename[0] && Filename[1] == ':' )
        return 1;

    return 0;
}

static const char* UE1AndroidRemapConfigFilenameRev38( const char* Filename, char* Out, size_t OutSize, int ForWrite )
{
    if( !Filename || OutSize < 16 )
        return Filename;

    if( !UE1AndroidConfigHasIniExtensionRev38( Filename ) )
        return Filename;

    if( UE1AndroidConfigIsAbsolutePathRev38( Filename ) )
        return Filename;

    const char* Root = getenv( "UE1_ANDROID_ROOT" );
    if( !Root || !Root[0] )
        Root = "/storage/emulated/0/Android/data/com.ast.unreal/files/Unreal";

    char SystemDir[4096];
    snprintf( SystemDir, sizeof(SystemDir), "%s/System", Root );
    SystemDir[sizeof(SystemDir) - 1] = 0;

    mkdir( Root, 0775 );
    mkdir( SystemDir, 0775 );

    const char* Base = UE1AndroidConfigBaseNameRev38( Filename );
    snprintf( Out, OutSize, "%s/%s", SystemDir, Base );
    Out[OutSize - 1] = 0;

    if( !ForWrite )
    {
        struct stat St;
        if( stat( Out, &St ) != 0 )
        {
            __android_log_print( ANDROID_LOG_INFO, "UE1Config", "Config read fallback: %s (persistent file missing)", Filename );
            return Filename;
        }
    }

    __android_log_print( ANDROID_LOG_INFO, "UE1Config", "Config %s remap: %s -> %s", ForWrite ? "write" : "read", Filename, Out );
    return Out;
}
#endif // PLATFORM_ANDROID
