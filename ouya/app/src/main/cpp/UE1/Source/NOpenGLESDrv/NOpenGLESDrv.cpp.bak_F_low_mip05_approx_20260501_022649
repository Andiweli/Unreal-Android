		OuyaGLState.ColorMask[0] != (UBOOL)(R != GL_FALSE) ||
		OuyaGLState.ColorMask[1] != (UBOOL)(G != GL_FALSE) ||
		OuyaGLState.ColorMask[2] != (UBOOL)(B != GL_FALSE) ||
		OuyaGLState.ColorMask[3] != (UBOOL)(A != GL_FALSE) )
