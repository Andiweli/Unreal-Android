INT UNOpenGLESRenderDevice::GetTextureUploadBaseMip( const FTextureInfo& Info ) const
{
	// Texture Detail policy for OUYA:
	//
	// HIGH:
	//   BaseMip 0, full source texture quality.
	//
	// Hard LOW from Patch B:
	//   BaseMip 1 for almost every normal paletted texture; very blurry.
	//
	// Too mild LOW from Patch D:
	//   BaseMip 1 only from 512px upward; barely visible.
	//
	// D2 medium LOW:
	//   BaseMip 1 from 256px upward.
	//   64/128px textures stay crisp, 256/512/1024px textures save one mip.
	if( !UseLowDetailTextures() )
		return 0;

	// Keep lightmaps/fogmaps and special translucent effect sprites untouched.
	if( !Info.Palette || Info.NumMips <= 1 || UE1GLESIsLegacyEffectSpriteTexture( Info ) )
		return 0;

	const FMipmap* Mip0 = Info.Mips[0];
	if( !Mip0 )
		return 0;

	if( Mip0->USize < 256 && Mip0->VSize < 256 )
		return 0;

	return 1;
}

void UNOpenGLESRenderDevice::UpdateLowDetailTextureMode()
{
	const UBOOL NewLowDetail = UseLowDetailTextures();
	if( NewLowDetail != CurrentLowDetailTextures )
	{
		debugf( NAME_Log, "OUYA texture detail changed to %s; flushing GLES texture cache", NewLowDetail ? "LOW" : "HIGH" );
		CurrentLowDetailTextures = NewLowDetail;
		Flush();
	}
}

void UNOpenGLESRenderDevice::Flush()
{
	guard(UNOpenGLESRenderDevice::Flush);

	if( TexAlloc.Num() )
	{
		debugf( NAME_Log, "Flushing %d/%d textures", TexAlloc.Num(), BindMap.Size() );
		ResetTexture( 0 );
		ResetTexture( 1 );
		ResetTexture( 2 );
		ResetTexture( 3 );
		glFinish();
		glDeleteTextures( TexAlloc.Num(), &TexAlloc(0) );
		TexAlloc.Empty();
		BindMap.Empty();
#if defined(UNREAL_ANDROID_OUYA)
		OuyaInvalidateUE1GLState();
#endif
	}

	unguard;
}

